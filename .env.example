# ─── PostgreSQL (Neon / Supabase / local) ───────────
# Neon ejemplo:
# DATABASE_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"
# Local (docker compose up -d):
# DATABASE_URL="postgresql://socialhub:socialhub@localhost:5432/socialhub?schema=public"
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"

# Auth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="dev-nextauth-secret-change-in-production-32c"
ADMIN_EMAIL="admin@socialhub.local"
ADMIN_PASSWORD="Admin123!"
RETAIL_EMAIL="retail@socialhub.local"
RETAIL_PASSWORD="Retail123!"

# App
APP_URL="http://localhost:3001"
PORT=3001
ALLOW_SEED="true"
SEED_SECRET="dev-seed-secret"
AUTOMATION_SERVICE_URL="http://localhost:3031"
# OPENAI_API_KEY=

# ─── OAuth redes (requerido para publicar en vivo) ──
# Callbacks (añade en cada app del proveedor):
#   {APP_URL}/api/oauth/facebook/callback
#   {APP_URL}/api/oauth/instagram/callback
#   {APP_URL}/api/oauth/tiktok/callback
#   {APP_URL}/api/oauth/x/callback
#   {APP_URL}/api/oauth/linkedin/callback
#   {APP_URL}/api/oauth/youtube/callback
#   {APP_URL}/api/oauth/pinterest/callback
# META_APP_ID=
# META_APP_SECRET=
# Optional: after enabling pages_manage_posts in Meta dashboard:
# META_FACEBOOK_SCOPES=public_profile,email,pages_show_list,pages_read_engagement,pages_manage_posts,pages_manage_engagement
# META_INSTAGRAM_SCOPES=public_profile,email,pages_show_list,pages_read_engagement,instagram_basic,instagram_content_publish
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# PINTEREST_APP_ID=
# PINTEREST_APP_SECRET=

